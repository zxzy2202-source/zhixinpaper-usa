# ─────────────────────────────────────────────────────────────────
# zhixinpaper-usa 环境变量样例
# 复制为 .env.local 后填写真实值（.env.local 已 gitignore）
# ─────────────────────────────────────────────────────────────────

# ── 数据库（必填）─ Turso / libSQL ────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=eyJxxx...
# 本地开发可改用：file:./data/zhixinpaper.db

# ── 鉴权（必填）─ Admin JWT 签名 ───────────────────────────────────
JWT_SECRET=run-openssl-rand-base64-32

# ── 媒体存储（必填）─ Vercel Blob ─────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# ── 询盘通知 ─ 通道 1：Server酱（强烈推荐，微信秒推） ──────────────
# 申请方法：
#   1) 访问 https://sct.ftqq.com
#   2) 微信扫码登录
#   3) 在 "SendKey" 页面复制 sendkey（形如 SCT123456...）
#   4) 关注 "Server酱·Turbo" 服务号即可接收推送
# 不填则跳过此通道，仍走邮件兜底。
SERVERCHAN_SENDKEY=

# ── 询盘通知 ─ 通道 2：Resend 邮件兜底 ────────────────────────────
RESEND_API_KEY=re_xxx
# 销售收件邮箱（不填默认 Sales@zxpapers.com）
NOTIFY_EMAIL_TO=Sales@zxpapers.com
# 发件地址（需在 Resend 已验证域名）
NOTIFY_EMAIL_FROM=Zhixin Paper Website <noreply@zhixinpaper.com>

# ── 站点 URL（用于 sitemap / canonical） ──────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.zhixinpaper.com
